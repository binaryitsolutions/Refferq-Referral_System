# ============================================
# REFFERQ - Environment Variables
# Copy this file to .env.local and fill in your values
# Author: Refferq Team
# ============================================

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/refferq"

# ============================================
# AUTHENTICATION
# ============================================
# Generate: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# ============================================
# EMAIL (Zeptomail)
# Get your API key from: https://zeptomail.zoho.com
# ============================================
ZEPTOMAIL_API_KEY="your-zeptomail-api-key-here"
ZEPTOMAIL_FROM_EMAIL="Refferq <noreply@yourdomain.com>"

# ============================================
# ADMIN
# ============================================
ADMIN_EMAILS="admin@yourdomain.com,admin2@yourdomain.com"

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# OPTIONAL: STRIPE
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""
